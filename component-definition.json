{
  "groups": [
    {
      "title": "Default Content",
      "id": "default",
      "components": [
        {
          "title": "Text",
          "id": "text",
          "plugins": {
            "da": {
              "unsafeHTML": "<p>Text goes here</p>"
            }
          }
        },
        {
          "title": "Image",
          "id": "image",
          "model": "image",
          "plugins": {
            "da": {
              "name": "image",
              "type": "image",
              "fields": [
                {
                  "name": "image",
                  "selector": "img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "img[alt]"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "title": "Sections",
      "id": "sections",
      "components": [
        {
          "title": "Section",
          "id": "section",
          "plugins": {
            "da": {
              "unsafeHTML": "<div></div>"
            }
          },
          "filter": "section",
          "model": "section"
        }
      ]
    },
    {
      "title": "Blocks",
      "id": "blocks",
      "components": [
        {
          "title": "Advanced Tabs",
          "id": "advanced-tabs",
          "model": "advanced-tabs",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"advanced-tabs\"><div><div><ul><li>Tab 1</li><li>Tab 2</li></ul></div></div></div>",
              "fields": [
                {
                  "name": "tabs",
                  "selector": "div>div>ul"
                }
              ]
            }
          }
        },
        {
          "title": "Card",
          "id": "card",
          "model": "card",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"card\"><div><div><picture><source type=\"image/webp\" srcset=\"\"><img loading=\"lazy\" alt=\"Card image\" src=\"\"></picture></div></div><div><div><p><strong>Card Title</strong></p><p>Card description goes here.</p></div></div></div>",
              "fields": [
                {
                  "name": "image",
                  "selector": "div:nth-child(1)>div>picture>img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "div:nth-child(1)>div>picture>img[alt]"
                },
                {
                  "name": "content",
                  "selector": "div:nth-child(2)>div"
                }
              ]
            }
          }
        },
        {
          "title": "Columns",
          "id": "columns",
          "model": "columns",
          "filter": "columns",
          "plugins": {
            "da": {
              "name": "columns",
              "rows": 1,
              "columns": 2,
              "behaviour": "columns"
            }
          }
        },
        {
          "title": "Columns Row",
          "id": "columns-row",
          "model": "columns-row",
          "filter": "columns-row",
          "plugins": {
            "da": {
              "name": "columns-row",
              "behaviour": "columns-row"
            }
          }
        },
        {
          "title": "Columns Cell",
          "id": "columns-cell",
          "model": "columns-cell",
          "filter": "columns-cell",
          "plugins": {
            "da": {
              "name": "columns-cell",
              "behaviour": "columns-cell"
            }
          }
        },
        {
          "title": "Fragment",
          "id": "fragment",
          "model": "fragment",
          "plugins": {
            "da": {
              "unsafeHTML": "<p><a href=\"/fragments/\">/fragments/</a></p>",
              "fields": [
                {
                  "name": "content",
                  "selector": "div"
                }
              ]
            }
          }
        },
        {
          "title": "Hero",
          "id": "hero",
          "model": "hero",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"hero\"><div><div><picture><img loading=\"lazy\" alt=\"\" src=\"https://main--author-kit--aemsites.aem.live/media_1674c029fe1c222fe6f72c3bf0ad7fdf41e16eca9.jpg\"></picture></div></div><div><div><h2>Hero Heading</h2><p>Description text goes here.</p><p><em><strong><a href=\"https://example.com\">Call to Action</a></strong></em></p></div></div></div>",
              "fields": [
                {
                  "name": "image",
                  "selector": "div:nth-child(1)>picture>img[src]"
                },
                {
                  "name": "content",
                  "selector": "div:nth-child(2)>div"
                }
              ]
            }
          }
        },
        {
          "title": "Schedule",
          "id": "schedule",
          "model": "schedule",
          "plugins": {
            "da": {
              "unsafeHTML": "<p><a href=\"/schedules/\">/schedules/</a></p>",
              "fields": [
                {
                  "name": "content",
                  "selector": "a"
                }
              ]
            }
          }
        },
        {
          "title": "Table",
          "id": "table",
          "model": "table",
          "plugins": {
            "da": {
              "name": "table",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "table",
                  "selector": "div>div"
                }
              ]
            }
          }
        },
        {
          "title": "YouTube",
          "id": "youtube",
          "model": "youtube",
          "plugins": {
            "da": {
              "unsafeHTML": "<p><a href=\"https://www.youtube.com/watch?v=\">https://www.youtube.com/watch?v=</a></p>",
              "fields": [
                {
                  "name": "content",
                  "selector": "a"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}